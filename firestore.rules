rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /schools/{schoolId} {
      // Allow read access to the school document itself
      allow read: if request.auth != null;

      // Allow read and write access to all subcollections under a school
      // for any authenticated user. This is a broad rule for simplicity in this app.
      match /{document=**} {
        allow read, write: if request.auth != null;
      }
    }
  }
}
