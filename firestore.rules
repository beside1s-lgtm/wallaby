rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Allow authenticated users to read any document in the database.
    // This is a temporary measure to allow the app to function with anonymous auth.
    // For more granular security, you would need to implement custom claims with a non-anonymous auth provider.
    match /{document=**} {
      allow read: if request.auth != null;
      allow write: if false; // Default deny writes
    }

    // Allow creating a new school document for any authenticated user (for registration).
    match /schools/{schoolId} {
      allow create: if request.auth != null;
      
      // Allow writing to subcollections if the user is authenticated.
      // A more secure rule would check for a 'teacher' role via custom claims.
      match /{collection}/{docId} {
        allow write: if request.auth != null;
      }
    }
  }
}
